# Production build default (PL-8 single-project deploy). Empty means "same
# origin": the frontend and the FastAPI backend are served from one Vercel
# project/domain, so the browser calls `/api/...` on the current origin and no
# CORS is involved. `api-client.ts` uses `process.env.NEXT_PUBLIC_API_URL ?? ...`
# and an empty string is a real value (not the localhost fallback). A Vercel
# dashboard env var, if set, still overrides this.
NEXT_PUBLIC_API_URL=
