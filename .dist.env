# Copy to `.env` and fill in. Consumed by docker-compose at the repo root.

# OpenRouter key for the AI chat (Cerebras-backed gpt-oss-120b). Without it the
# chat endpoints return 503.
OPENROUTER_API_KEY=

# Secret used to sign user session tokens (PL-7). Set a long random value in
# production; if unset, a development default is used.
PRELEGAL_SESSION_SECRET=

# Base URL the browser uses to reach the backend (baked into the frontend build).
NEXT_PUBLIC_API_URL=http://localhost:8000
