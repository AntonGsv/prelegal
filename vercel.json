{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend && npm install && STATIC_EXPORT=1 npm run build && rm -rf ../backend/static && cp -r out ../backend/static",
  "outputDirectory": "frontend/out",
  "build": {
    "env": {
      "UV_PYTHON": "3.12"
    }
  },
  "functions": {
    "api/index.py": {
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
