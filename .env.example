# Backend
PRELEGAL_DATABASE_URL=file:./data/prelegal.db
PRELEGAL_CORS_ORIGINS=http://localhost:3000

# AI chat (required for the NDA assistant) — get a key at https://openrouter.ai
# Docker Compose forwards this into the backend container.
OPENROUTER_API_KEY=

# Frontend → backend base URL (baked into the browser bundle at build time).
# Defaults to http://localhost:8000; override only if the backend is elsewhere.
NEXT_PUBLIC_API_URL=http://localhost:8000
