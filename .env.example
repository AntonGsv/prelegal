# Backend
# Local dev uses a SQLite file. For a hosted (Vercel/Turso) deploy, set this to
# your Turso URL, e.g. libsql://your-db.turso.io, and provide the auth token.
PRELEGAL_DATABASE_URL=file:./data/prelegal.db
# Turso auth token (required only for a remote libsql:// URL; leave blank for a
# local file: URL). `DB_TOKEN` is also accepted as a fallback name.
PRELEGAL_DATABASE_AUTH_TOKEN=
PRELEGAL_CORS_ORIGINS=http://localhost:3000

# AI chat (required for the NDA assistant) — get a key at https://openrouter.ai
# Docker Compose forwards this into the backend container.
OPENROUTER_API_KEY=

# Frontend → backend base URL (baked into the browser bundle at build time).
# Defaults to http://localhost:8000; override only if the backend is elsewhere.
NEXT_PUBLIC_API_URL=http://localhost:8000
